{
  "name": "t:sections.starmap_generator.name",
  "tag": "section",
  "class": "starmap-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.starmap_generator.settings.product.label"
    },
    {
      "type": "header",
      "content": "t:sections.starmap_generator.settings.content_header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.starmap_generator.settings.heading.label",
      "default": "Design your map"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.starmap_generator.settings.description.label",
      "default": "Enter the details of your special moment to generate your unique star map."
    }
  ],
  "presets": [
    {
      "name": "t:sections.starmap_generator.presets.name"
    }
  ]
}
{% endschema %}
